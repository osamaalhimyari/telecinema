# Dependencies and AdonisJS build
node_modules
build
tmp/*
!tmp/.gitkeep

# Project archives/backups — never commit (bloats the repo by 100s of MB)
*.zip

# Secrets
.env
.env.local
.env.production.local
.env.development.local

# Frontend assets compiled code
public/assets

# Build tools specific
npm-debug.log
yarn-error.log

# Editors specific
.fleet
.idea
.vscode
.claude

# Platform specific
.DS_Store

# Downloaded media (keep large video files out of git)
storage/videos/*
!storage/videos/README.md
!storage/videos/.gitkeep

# Torrent cache — never commit the large video files (subtitles/posters are fine)
storage/torrents/**/*.mp4
storage/torrents/**/*.mkv
storage/torrents/**/*.avi
storage/torrents/**/*.webm
storage/torrents/**/*.m4v
storage/torrents/**/*.mov
