<?xml version="1.0" encoding="utf-8"?>
<!--
  MonsterASP.NET Node.js hosting (IIS httpPlatformHandler).
  Upload the *contents* of the build/ folder into wwwroot. This file lands at
  wwwroot/web.config and launches AdonisJS via bin/server.js.

  - PORT is injected by the platform; AdonisJS reads it from process.env.PORT.
  - stdoutLog is ON so you can read startup errors in wwwroot/logs/ on first
    deploy (the better-sqlite3 native module is the most likely thing to fail).
    Turn it off once the app boots cleanly.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="node"
                  arguments=".\bin\server.js"
                  startupTimeLimit="60"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\node">
      <environmentVariables>
        <!-- httpPlatformHandler picks a random port and exposes it as
             %HTTP_PLATFORM_PORT%. AdonisJS reads process.env.PORT, so map it
             across or the server binds to the wrong port -> HTTP 502.5. -->
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NODE_ENV" value="production" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
