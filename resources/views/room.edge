<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ room.name }} — Watch Party</title>
    <link rel="stylesheet" href="/css/app.css?v=24" />
    <script src="/js/guard.js?v=21"></script>
  </head>
  <body class="page-room">
    @include('partials/flash')

    <div class="room-topbar">
      <a class="room-back" href="/">‹ Rooms</a>
      <h1 class="room-title" id="roomTitle">{{ room.name }}</h1>
      <div class="presence-area" id="presenceArea">
        <button class="room-presence-btn" id="presenceBtn" type="button" title="Who's watching">
          <span class="presence-avatars" id="presenceAvatars"></span>
          <span class="presence-count" id="presenceCount">0</span>
        </button>
        <div class="presence-popover" id="presencePopover" hidden>
          <div class="presence-list" id="presenceList"></div>
        </div>
      </div>
      <span class="viewer-badge">
        <span class="live-dot"></span>
        <span class="viewer-count" id="viewerCount">0</span>
        <span class="viewer-label">watching</span>
      </span>
      <button class="room-share-btn" id="chatToggle" type="button" title="Toggle chat (C)">
        💬<span class="chat-toggle-badge" id="chatToggleBadge" hidden>0</span>
      </button>

      {{-- Hamburger trigger — only shown at narrow widths via CSS. --}}
      <button
        class="topbar-menu-toggle"
        id="topbarMenuToggle"
        type="button"
        aria-label="More actions"
        aria-haspopup="true"
        aria-expanded="false"
      >☰</button>

      {{-- Action buttons. On desktop they sit inline; on mobile this
           wrapper becomes an absolutely-positioned dropdown opened by
           the hamburger trigger. --}}
      <div class="topbar-actions" id="topbarActions">
        <button class="room-share-btn" id="shareBtn" type="button" title="Copy room link">
          <span class="topbar-action-icon">⤴</span>
          <span class="topbar-action-label">Share</span>
        </button>
        <button class="room-delete-btn" id="editBtn" type="button">Edit</button>
        <button class="room-delete-btn" id="deleteBtn" type="button">Delete</button>
      </div>
    </div>

    <main class="player-stage" id="playerStage">
      <div class="player {{ room.roomType === 'external' ? 'player--external' : '' }}" id="player">
        {{-- The rotor wraps the video/iframe and both control bars. --}}
        <div class="player-rotor" id="playerRotor">
          @if(room.roomType === 'external')
            {{-- Embed the third-party player as-is. Sandbox is intentionally
                 not applied — most embed pages need scripts and same-origin
                 cookies to play. The `data-base` attribute holds the clean
                 URL so room.js can rebuild the src with a `?t=N` parameter
                 whenever the room playhead jumps. --}}
            <iframe
              id="externalEmbed"
              class="player-embed"
              src="{{ room.externalUrl }}"
              data-base="{{ room.externalUrl }}"
              allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>

            {{-- Paused overlay sits INSIDE the rotor, with a z-index above
                 the iframe but below the controls — so the visitor can still
                 press play to resume the room. --}}
            <div class="player-overlay external-paused" id="externalPausedOverlay">
              <div class="overlay-card">
                <div class="overlay-icon">⏸</div>
                <div class="overlay-title">Paused for the room</div>
                <div class="overlay-sub">Press play to resume — everyone restarts together.</div>
              </div>
            </div>

          @elseif(room.roomType === 'torrent')
            {{-- Torrent rooms stream peer-to-peer IN THE BROWSER (WebTorrent
                 over WebRTC), like the mobile app streams on-device — the
                 server only carries the play/pause/seek sync, not the bytes.
                 If no web peers are reachable, room.js falls back to the
                 server's /stream/:slug (the full TCP/UDP swarm). The magnet and
                 that fallback URL ride on data-* attributes; room.js sets the
                 actual `src`. The raw magnet is otherwise never sent to clients,
                 but the web player needs it to join the swarm itself. --}}
            <video
              id="video"
              class="player-video"
              data-magnet="{{ room.magnet || '' }}"
              data-fallback="/stream/{{ room.slug }}"
              preload="auto"
              playsinline
            ></video>
          @elseif(room.roomType === 'youtube')
            {{-- youtube rooms STREAM from the server — they are never downloaded.
                 yt-dlp resolves the watch URL to a direct googlevideo stream,
                 which the server proxies (range-supported) over /youtube/:slug,
                 so the browser plays it as an ordinary synced <video> — no
                 third-party iframe and no file on disk. --}}
            <video
              id="video"
              class="player-video"
              src="/youtube/{{ room.slug }}"
              preload="auto"
              playsinline
            ></video>
          @else
            {{-- upload/download rooms serve a file on disk from /video/:filename,
                 a range-supported <video> source. --}}
            <video
              id="video"
              class="player-video"
              src="/video/{{ room.videoFilename }}"
              preload="auto"
              playsinline
            ></video>
          @end

          {{-- Subtitle overlay — JS writes the current cue text into the inner
               span and applies the room's shared weight/size. Empty by default;
               rendered in front of the video/iframe so it stays readable on
               every room type. --}}
          <div class="subtitle-overlay" id="subtitleOverlay">
            <span class="subtitle-text" id="subtitleText"></span>
          </div>

          {{-- Collaborative drawing surface — renders every viewer's ephemeral
               strokes over the video (local echo + relayed `draw` events), each
               fading on its own. Pointer-transparent until draw mode is engaged
               (room.js toggles `.is-drawing` on the player to capture touches). --}}
          <canvas class="draw-canvas" id="drawCanvas"></canvas>

          {{-- Top controls: speaking indicator + viewer count + fullscreen --}}
          <div class="top-controls" id="topControls">
            <span class="voice-indicator" id="voiceIndicator" aria-live="polite">
              <span class="voice-wave"></span>
              <span class="voice-speaker-name" id="voiceSpeakerName"></span>
            </span>

            {{-- Viewer count — only shown in fullscreen, where the topbar is hidden --}}
            <span class="viewer-badge viewer-badge--player" id="viewerBadgeFs">
              <span class="live-dot"></span>
              <span class="viewer-count" id="viewerCountFs">0</span>
              <span class="viewer-label">watching</span>
            </span>

            @if(room.roomType === 'external')
              <button
                class="ctrl-btn"
                id="sourceBtn"
                type="button"
                aria-label="Change the embed source URL"
                title="Change source (next episode, different server, …)"
              >🎞</button>
              <button
                class="ctrl-btn"
                id="resyncBtn"
                type="button"
                aria-label="Resync everyone to the room time"
                title="Resync everyone — reloads each iframe at the room time"
              >↻</button>
            @else
              <button
                class="ctrl-btn"
                id="speedBtn"
                type="button"
                aria-label="Playback speed (synced)"
                title="Playback speed — synced across the room"
              >1×</button>
              <button
                class="ctrl-btn"
                id="pipBtn"
                type="button"
                aria-label="Picture in Picture"
                title="Picture-in-Picture"
              >⧉</button>
            @end
            {{-- Subtitles work on every room type now: file/torrent rooms get a
                 JS overlay over the <video>, external rooms over the iframe. --}}
            <button
              class="ctrl-btn"
              id="subtitleBtn"
              type="button"
              aria-label="Subtitles"
              title="Subtitles — search online or upload (.srt or .vtt)"
            >CC</button>
            <button
              class="ctrl-btn"
              id="subtitleSettingsBtn"
              type="button"
              aria-label="Subtitle settings"
              title="Subtitle settings — timing, thickness, size"
            >⚙</button>
            <button class="ctrl-btn" id="fullscreen" type="button" aria-label="Toggle fullscreen" title="Fullscreen">⛶</button>
          </div>

          <div class="controls" id="controls">
            {{-- Seek row sits above the buttons — same shape YouTube uses.
                 External rooms get the same synced timeline; we just don't
                 know the duration up front, so the right-hand label shows
                 the room's "live" elapsed time instead. --}}
            <div class="controls-row controls-row--seek">
              <span class="time-label" id="curTime">0:00</span>
              <input
                class="seek-bar"
                id="seek"
                type="range"
                min="0"
                max="100"
                step="0.1"
                value="0"
                aria-label="Seek"
              />
              <span class="time-label" id="durTime">{{ room.roomType === 'external' ? 'LIVE' : '0:00' }}</span>
            </div>

            <div class="controls-row controls-row--buttons">
              <div class="controls-side controls-side--left"></div>
              <div class="controls-center">
                <button class="ctrl-btn" id="back10" type="button" aria-label="Back 10 seconds">« 10s</button>
                <button class="ctrl-btn" id="playPause" type="button" aria-label="Play or pause">▶</button>
                <button
                  class="ctrl-btn mic-btn"
                  id="micBtn"
                  type="button"
                  aria-label="Hold to talk"
                  title="Hold to talk"
                >🎙</button>
                <button class="ctrl-btn" id="fwd10" type="button" aria-label="Forward 10 seconds">10s »</button>
              </div>
              <div class="controls-side controls-side--right"></div>
            </div>
          </div>
        </div>

        {{-- "Wait for slow viewers" banner — top-center pill that names
             whoever is currently buffering. Shown by the wait_state
             socket event; hidden when the list is empty. --}}
        <div class="wait-banner" id="waitBanner" aria-live="polite">
          <span class="wait-banner-spinner" aria-hidden="true"></span>
          <span class="wait-banner-label" id="waitBannerLabel"></span>
        </div>

        {{-- Chat flyovers — incoming chat messages briefly appear over the
             player in the bottom-left corner so every viewer sees them
             without opening the side panel. Pointer events are disabled so
             the overlay never blocks the video controls. --}}
        <div class="chat-flyovers" id="chatFlyovers" aria-live="polite" aria-atomic="false"></div>

        {{-- Reaction toggle button (top-left corner) — opens/closes the floating emoji tray --}}
        <button class="reaction-toggle" id="reactionToggle" type="button" title="Reactions" aria-label="Toggle reaction tray">😊</button>

        {{-- Floating reaction tray — appears when toggle is pressed, stays open until dismissed --}}
        <div class="reaction-tray" id="reactionTray">
          @each(emoji in room.reactionsList)
            <button class="reaction-btn" data-reaction="{{ emoji }}" type="button">{{ emoji }}</button>
          @end
        </div>

        {{-- Draw toggle (top-right corner) — engages drawing mode; the pen
             palette appears while it's on. Mirrors the mobile app's pen tool. --}}
        <button class="draw-toggle" id="drawToggle" type="button" title="Draw on the video (D)" aria-label="Toggle drawing">✏️</button>

        {{-- Pen palette — pick a color, or close. Shown only while drawing. The
             swatch colors match the mobile app's palette exactly. --}}
        <div class="draw-palette" id="drawPalette" hidden>
          <button class="draw-swatch is-selected" type="button" data-color="#FF5252" style="--swatch: #FF5252" aria-label="Red pen"></button>
          <button class="draw-swatch" type="button" data-color="#FF9800" style="--swatch: #FF9800" aria-label="Orange pen"></button>
          <button class="draw-swatch" type="button" data-color="#FFEB3B" style="--swatch: #FFEB3B" aria-label="Yellow pen"></button>
          <button class="draw-swatch" type="button" data-color="#69F0AE" style="--swatch: #69F0AE" aria-label="Green pen"></button>
          <button class="draw-swatch" type="button" data-color="#40C4FF" style="--swatch: #40C4FF" aria-label="Blue pen"></button>
          <button class="draw-swatch" type="button" data-color="#E040FB" style="--swatch: #E040FB" aria-label="Purple pen"></button>
          <button class="draw-swatch" type="button" data-color="#FFFFFF" style="--swatch: #FFFFFF" aria-label="White pen"></button>
          <button class="draw-swatch" type="button" data-color="#000000" style="--swatch: #000000" aria-label="Black pen"></button>
          <span class="draw-palette-divider" aria-hidden="true"></span>
          <button class="draw-palette-close" id="drawPaletteClose" type="button" aria-label="Stop drawing">×</button>
        </div>

        {{-- Overlays sit outside the rotor so messages stay upright --}}

        {{-- Join overlay — shown on page load to collect display name (and
             password for locked rooms). Replaces the old `prompt()` dialog
             and the separate room_locked page. --}}
        <div class="player-overlay join-overlay" id="joinOverlay">
          <div class="overlay-card join-card">
            <div class="overlay-icon">🎬</div>
            <div class="overlay-title" id="joinTitle">Join "{{ room.name }}"</div>
            <div class="overlay-sub">Enter a display name to join the watch party.</div>

            <div class="field">
              <label class="field-label" for="joinName">Your display name</label>
              <input
                class="field-input"
                id="joinName"
                type="text"
                maxlength="30"
                placeholder="e.g. MovieFan42"
                autocomplete="off"
              />
            </div>

            @if(room.hasPassword && !roomUnlocked)
              <div class="field" id="joinPasswordField" hidden>
                <label class="field-label" for="joinPassword">Room password</label>
                <input
                  class="field-input"
                  id="joinPassword"
                  type="password"
                  placeholder="Enter room password"
                  autocomplete="current-password"
                />
              </div>
            @end

            <p class="form-error" id="joinError" hidden></p>

            <button class="btn-primary btn-block" id="joinBtn" type="button">Join</button>
          </div>
        </div>

        @if(room.roomType !== 'external')
          {{-- Shown when unmuted autoplay is blocked after the join overlay
               is dismissed — browser gesture context may have expired. --}}
          <div class="player-overlay player-gate" id="playGate">
            <div class="overlay-card">
              <div class="overlay-icon">▶</div>
              <div class="overlay-title">Tap to play</div>
              <div class="overlay-sub">Press play to resume — everyone restarts together.</div>
            </div>
          </div>

          @if(room.roomType === 'torrent')
            {{-- Torrent bytes come from the swarm via the server. While it warms
                 up (finding seeders / fetching metadata) we show this and retry
                 the stream, instead of flashing the error overlay. Mirrors the
                 mobile app's "preparing torrent" state. --}}
            <div class="player-overlay player-error" id="videoPreparing">
              <div class="overlay-card">
                <div class="overlay-icon">⏳</div>
                <div class="overlay-title">Preparing stream…</div>
                <div class="overlay-sub">
                  Finding sources in the swarm — this can take a moment.
                </div>
              </div>
            </div>
          @end

          {{-- Shown when the source can't be played: a missing file for
               upload/download rooms, or a torrent with no reachable peers. --}}
          <div class="player-overlay player-error" id="videoError">
            <div class="overlay-card">
              <div class="overlay-icon">⚠</div>
              @if(room.roomType === 'torrent')
                <div class="overlay-title">Stream unavailable</div>
                <div class="overlay-sub">
                  Couldn't reach the torrent swarm. It may have no seeders right now — try again shortly.
                </div>
              @else
                <div class="overlay-title">Video file not found</div>
                <div class="overlay-sub">
                  Add <code>{{ room.videoFilename }}</code> to <code>storage/videos/</code>.
                </div>
              @end
            </div>
          </div>
        @end

        {{-- Chat toggle for fullscreen — the top bar's 💬 sits outside the
             player, so it vanishes in native fullscreen; this in-player button
             (shown only while fullscreen) opens the same chat panel. --}}
        <button class="player-chat-toggle" id="fsChatToggle" type="button" title="Toggle chat" aria-label="Toggle chat">
          💬<span class="chat-toggle-badge" id="fsChatToggleBadge" hidden>0</span>
        </button>

        {{-- Chat sidebar — a slide-over panel. Kept INSIDE the player so it
             still renders when the player is in native fullscreen (only the
             fullscreened element's subtree is shown). Driven by Socket.io: each
             message is broadcast to the room, including the sender, so every
             client renders through the same DOM path. --}}
        <aside class="chat-panel" id="chatPanel" aria-label="Room chat">
        <header class="chat-header">
          <span class="chat-title">Chat</span>
          <button class="chat-close" id="chatClose" type="button" aria-label="Close chat">×</button>
        </header>
        <div class="chat-messages" id="chatMessages" aria-live="polite">
          <p class="chat-empty" id="chatEmpty">No messages yet — say hi 👋</p>
        </div>
        <form class="chat-form" id="chatForm" autocomplete="off">
          <input
            class="chat-input"
            id="chatInput"
            type="text"
            maxlength="500"
            placeholder="Send a message…"
            aria-label="Message"
          />
          <button class="chat-send" id="chatSend" type="submit" aria-label="Send message">➤</button>
        </form>
      </aside>
      </div>
    </main>

    {{-- Edit room modal --}}
    <div class="modal" id="editModal" aria-hidden="true">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="editModalTitle">
        <h2 class="modal-title" id="editModalTitle">Edit room settings</h2>
        <div class="field">
          <label class="field-label" for="editName">Room name</label>
          <input class="field-input" id="editName" type="text" maxlength="80" value="{{ room.name }}" />
        </div>
        <div class="field">
          <label class="field-label" for="editPassword">New password <span class="field-hint">leave blank to keep current</span></label>
          <input class="field-input" id="editPassword" type="password" autocomplete="new-password" />
        </div>
        @if(room.hasPassword)
          <div class="field">
            <label class="field-label" for="editCurrentPassword">Current password <span class="field-hint">required</span></label>
            <input class="field-input" id="editCurrentPassword" type="password" autocomplete="current-password" required />
          </div>
        @end
        <div class="field">
          <label class="field-label">Reactions <span class="field-hint">pick up to 8</span></label>
          <div class="emoji-picker" id="editEmojiPicker">
            <input type="hidden" id="editReactionsInput" value='{{ JSON.stringify(room.reactionsList) }}' />
            <div class="emoji-selected" id="editEmojiSelected"></div>
            <div class="emoji-grid" id="editEmojiGrid"></div>
            <button class="emoji-toggle" id="editEmojiToggle" type="button">Show all emojis</button>
          </div>
        </div>
        <script>
          var EMOJI_LIST = '👍,👎,❤️,😂,🤣,😊,😍,😎,🥰,🥳,🤩,👏,🙌,🙏,✨,🔥,🎉,💯,🤯,😮,😱,😭,😢,😅,😌,😴,😈,🤔,🤫,🙈,👀,💀,🥶,🍿,🎬,🎊,🎵,💥,🤝,🤘,🎧,🌈,💙,💛,🧡,💜,🥺,😡,😤,😮‍💨,✅,❌,💖,🥱,🥵'.split(',')
          ;(function () {
            var picker = document.getElementById('editEmojiPicker')
            var input = document.getElementById('editReactionsInput')
            var grid = document.getElementById('editEmojiGrid')
            if (!picker || !input || !grid) return
            var selected = []
            try { selected = JSON.parse(input.value || '[]') } catch (e) {}
            EMOJI_LIST.forEach(function (emoji) {
              var btn = document.createElement('button')
              btn.className = 'emoji-opt'
              btn.type = 'button'
              btn.setAttribute('data-emoji', emoji)
              btn.textContent = emoji
              grid.appendChild(btn)
            })
            input.value = JSON.stringify(selected.length ? selected : ['👍','❤️','😂','😮','🎉','🔥','👏','💯'])
          })()
        </script>
        <p class="form-error" id="editModalError" hidden></p>
        <div class="modal-actions">
          <button class="btn-ghost" id="cancelEdit" type="button">Cancel</button>
          <button class="btn-primary" id="confirmEdit" type="button">Save</button>
        </div>
      </div>
    </div>

    {{-- Keyboard shortcuts help overlay --}}
    <div class="modal" id="shortcutsModal" aria-hidden="true">
      <div class="modal-card modal-card--narrow" role="dialog" aria-modal="true" aria-labelledby="shortcutsModalTitle">
        <h2 class="modal-title" id="shortcutsModalTitle">Keyboard shortcuts</h2>
        <div class="shortcuts-grid">
          <span class="shortcut-key">Space</span><span class="shortcut-desc">Play / Pause</span>
          <span class="shortcut-key">←</span><span class="shortcut-desc">Back 10s</span>
          <span class="shortcut-key">→</span><span class="shortcut-desc">Forward 10s</span>
          <span class="shortcut-key">↑</span><span class="shortcut-desc">Forward 60s</span>
          <span class="shortcut-key">↓</span><span class="shortcut-desc">Back 60s</span>
          <span class="shortcut-key">F</span><span class="shortcut-desc">Fullscreen</span>
          <span class="shortcut-key">M</span><span class="shortcut-desc">Mic (hold to talk)</span>
          <span class="shortcut-key">D</span><span class="shortcut-desc">Draw on video</span>
          <span class="shortcut-key">C</span><span class="shortcut-desc">Toggle chat</span>
          <span class="shortcut-key">?</span><span class="shortcut-desc">Show shortcuts</span>
        </div>
        <div class="modal-actions">
          <button class="btn-primary" id="closeShortcutsBtn" type="button">Got it</button>
        </div>
      </div>
    </div>

    {{-- Delete confirmation modal --}}
    <div class="modal" id="deleteModal" aria-hidden="true">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
        <h2 class="modal-title" id="deleteModalTitle">Delete this room?</h2>
        <p class="modal-text">
          This permanently removes <strong>{{ room.name }}</strong>@if(room.roomType !== 'external') and its video file@end. The room
          can only be deleted while nobody else is watching.
        </p>

        <form method="POST" action="/room/{{ room.slug }}/delete">
          {{ csrfField() }}

          @if(room.hasPassword)
            <div class="field">
              <label class="field-label" for="deletePassword">Room password</label>
              <input
                class="field-input"
                id="deletePassword"
                name="password"
                type="password"
                placeholder="Enter the room password"
                autocomplete="current-password"
                required
              />
            </div>
          @end

          <div class="modal-actions">
            <button class="btn-ghost" id="cancelDelete" type="button">Cancel</button>
            <button class="btn-danger" type="submit">Delete room</button>
          </div>
        </form>
      </div>
    </div>

    @if(room.roomType === 'external')
      {{-- Change-source modal: paste a new embed URL (e.g. next episode)
           and broadcast it to every viewer. The new source resets the room
           clock to 0 and clears the previous subtitle. --}}
      <div class="modal" id="sourceModal" aria-hidden="true">
        <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="sourceModalTitle">
          <h2 class="modal-title" id="sourceModalTitle">Change source URL</h2>
          <p class="modal-text">
            Everyone in the room will reload to this URL and the room clock will reset to 0.
          </p>

          <div class="field">
            <label class="field-label" for="newSourceUrl">New embed URL</label>
            <input
              class="field-input"
              id="newSourceUrl"
              type="url"
              maxlength="2048"
              placeholder="https://example.com/embed/..."
            />
          </div>

          <p class="form-error" id="sourceModalError" hidden></p>

          <div class="modal-actions">
            <button class="btn-ghost" id="cancelSource" type="button">Cancel</button>
            <button class="btn-primary" id="confirmSource" type="button">Change source</button>
          </div>
        </div>
      </div>

    @end

    {{-- Subtitle modal — available on every room type. Two ways to get a
         subtitle onto the room: search OpenSubtitles (proxied by the server to
         dodge CORS) or upload an .srt/.vtt. Either path stores the file on the
         room and broadcasts it to everyone. --}}
    <div class="modal" id="subtitleModal" aria-hidden="true">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="subtitleModalTitle">
        <h2 class="modal-title" id="subtitleModalTitle">Subtitles</h2>

        <div class="sub-section">
          <div class="sub-section-title">Search online</div>
          <div class="sub-search-row">
            <input
              class="field-input"
              id="subtitleQuery"
              type="text"
              maxlength="120"
              placeholder="Movie or show name…"
            />
            <select class="field-input sub-lang" id="subtitleLang" aria-label="Subtitle language"></select>
          </div>
          <div class="sub-search-row">
            <input
              class="field-input sub-se"
              id="subtitleSeason"
              type="number"
              min="1"
              max="99"
              placeholder="Season"
              aria-label="Season (optional)"
            />
            <input
              class="field-input sub-se"
              id="subtitleEpisode"
              type="number"
              min="1"
              max="999"
              placeholder="Episode"
              aria-label="Episode (optional)"
            />
            <button class="btn-primary sub-search-btn" id="subtitleSearchBtn" type="button">Search</button>
          </div>
          <div class="sub-results" id="subtitleResults" aria-live="polite"></div>
        </div>

        <div class="sub-divider"><span>or</span></div>

        <div class="sub-section">
          <div class="sub-section-title">Upload a file</div>
          <div class="field">
            <input
              class="field-input"
              id="subtitleFile"
              type="file"
              accept=".srt,.vtt,text/vtt,application/x-subrip"
            />
          </div>
          <div class="modal-actions modal-actions--tight">
            <button class="btn-ghost" id="confirmSubtitle" type="button">Upload file</button>
          </div>
        </div>

        <p class="form-error" id="subtitleModalError" hidden></p>

        <div class="modal-actions">
          <button class="btn-ghost" id="cancelSubtitle" type="button">Close</button>
        </div>
      </div>
    </div>

    {{-- Subtitle settings modal — the room's shared timing offset, text
         thickness and size. Mirrors the mobile app's settings sheet and is
         wired to the same set_subtitle_settings socket event, so dragging a
         slider updates the look for everyone in the room. --}}
    <div class="modal" id="subtitleSettingsModal" aria-hidden="true">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="subtitleSettingsTitle">
        <h2 class="modal-title" id="subtitleSettingsTitle">Subtitle settings</h2>
        <p class="modal-text">These apply for everyone in the room.</p>

        <div class="sub-preview"><span class="subtitle-text" id="subtitlePreviewText">AaBb — أبجد</span></div>

        <div class="sub-setting">
          <div class="sub-setting-head">
            <span class="field-label">Timing</span>
            <span class="sub-setting-value" id="subtitleTimingLabel">In sync</span>
          </div>
          <input
            class="sub-range"
            id="subtitleTimingRange"
            type="range"
            min="-60"
            max="60"
            step="0.1"
            value="0"
            aria-label="Subtitle timing offset"
          />
          <div class="sub-setting-foot">
            <span class="field-hint">Negative = earlier, positive = later</span>
            <button class="btn-ghost sub-reset" id="subtitleTimingReset" type="button">Reset</button>
          </div>
        </div>

        <div class="sub-setting">
          <div class="sub-setting-head">
            <span class="field-label">Thickness</span>
            <span class="sub-setting-value" id="subtitleWeightLabel">500</span>
          </div>
          <input
            class="sub-range"
            id="subtitleWeightRange"
            type="range"
            min="100"
            max="900"
            step="100"
            value="500"
            aria-label="Subtitle thickness"
          />
        </div>

        <div class="sub-setting">
          <div class="sub-setting-head">
            <span class="field-label">Size</span>
            <span class="sub-setting-value" id="subtitleSizeLabel">28</span>
          </div>
          <input
            class="sub-range"
            id="subtitleSizeRange"
            type="range"
            min="14"
            max="44"
            step="1"
            value="28"
            aria-label="Subtitle size"
          />
        </div>

        <div class="modal-actions">
          <button class="btn-primary" id="closeSubtitleSettings" type="button">Done</button>
        </div>
      </div>
    </div>

    @if(room.roomType === 'torrent')
      {{-- Browser BitTorrent engine — only loaded for torrent rooms, which
           stream peer-to-peer in the browser before falling back to the
           server. ~240 KB, so kept off every other room type. --}}
      <script src="/js/webtorrent.min.js?v=22"></script>
    @end
    <script src="/socket.io/socket.io.js"></script>
    <script>
      window.ROOM_SLUG = "{{ room.slug }}"
      window.ROOM_TYPE = "{{ room.roomType }}"
      window.ROOM_SUBTITLE = "{{ room.subtitleFilename || '' }}"
      window.ROOM_NAME = "{{ room.name }}"
      window.ROOM_HAS_PASSWORD = {{ room.hasPassword ? 'true' : 'false' }}
      window.ROOM_UNLOCKED = {{ roomUnlocked ? 'true' : 'false' }}
      window.showToast = function (message, type) {
        var t = document.createElement('div')
        t.className = 'toast' + (type ? ' toast--' + type : '')
        t.textContent = message
        document.body.appendChild(t)
        t.offsetHeight
        t.classList.add('is-visible')
        setTimeout(function () {
          t.classList.remove('is-visible')
          setTimeout(function () { t.remove() }, 300)
        }, 4000)
      }
    </script>
    <script src="/js/room.js?v=27"></script>
  </body>
</html>
