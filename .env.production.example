# Production env for MonsterASP.NET.
# Copy this to a file named ".env" and upload it into wwwroot (next to web.config).
# Do NOT commit the real file — it holds APP_KEY.

TZ=UTC

# Bind all interfaces; httpPlatformHandler forwards requests here locally.
HOST=0.0.0.0

NODE_ENV=production
LOG_LEVEL=info

# Reuse the APP_KEY from your local .env — generating a new one invalidates
# existing sessions/cookies. Keep it secret.
APP_KEY=e_rFLm-UxiM23sxUuRNt3xHyG-ZvEgZJ

# Your live site URL on MonsterASP.
APP_URL=https://telecinema.runasp.net

SESSION_DRIVER=cookie

# Database: MySQL (mysql2) — no native binary, so no ERR_DLOPEN_FAILED.
# Create the DB in the MonsterASP control panel and paste its connection
# details below. Run migrations + seed LOCALLY against this same remote DB
# (there is no CLI on the host); the deployed app just connects to it.
DB_CONNECTION=mysql
DB_HOST=your-monsterasp-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_DATABASE=your-db-name

# NOTE: Do NOT set PORT here. MonsterASP injects it via httpPlatformHandler and
# AdonisJS reads process.env.PORT automatically.
